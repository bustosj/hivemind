// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Partner can read (to get push token for notifications)
      allow read: if request.auth != null;
    }

    // Punch cards — participants array controls access
    match /punchCards/{cardId} {
      allow read:   if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.owner;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.owner;
    }

    // Checklists — same pattern
    match /checklists/{listId} {
      allow read:   if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.owner;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.owner;
    }

    // Invite codes
    match /invites/{code} {
      // Anyone signed in can read (to validate a code they received)
      allow read:   if request.auth != null;
      // Only the creator can write their own invite
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.createdBy;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.createdBy;
    }


    match /partners/{pairId} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == resource.data.userA
                          || request.auth.uid == resource.data.userB);
    }
  }
}
